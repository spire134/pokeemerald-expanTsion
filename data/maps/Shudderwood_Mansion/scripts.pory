mapscripts Shudderwood_Mansion_MapScripts {}

// Reusable script for random wild encounters - place triggers where you want encounters
script Shudderwood_Mansion_RandomEncounter {
    lock
    playmoncry(SPECIES_MISDREAVUS, 0)
    waitmoncry
    msgbox(format("Something is stirring in the shadows!"))
    random(12)  // 12 different Pokemon in the encounter table
    switch (var(VAR_RESULT)) {
        case 0: call(Shudderwood_Encounter_Sinistea)
        case 1: call(Shudderwood_Encounter_Litwick)
        case 2: call(Shudderwood_Encounter_Gothita)
        case 3: call(Shudderwood_Encounter_Minccino)
        case 4: call(Shudderwood_Encounter_Duskull_35)
        case 5: call(Shudderwood_Encounter_Duskull_36)
        case 6: call(Shudderwood_Encounter_Minccino_37)
        case 7: call(Shudderwood_Encounter_Gothorita)
        case 8: call(Shudderwood_Encounter_Lampent_37)
        case 9: call(Shudderwood_Encounter_Dusclops_37)
        case 10: call(Shudderwood_Encounter_Lampent_38)
        case 11: call(Shudderwood_Encounter_Dusclops_38)
    }
    release
    end
}

// Individual encounter scripts
script Shudderwood_Encounter_Sinistea {
    setwildbattle(SPECIES_SINISTEA, 34)
    dowildbattle
    return
}

